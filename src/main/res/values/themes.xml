<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.EasyNote" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryDark</item>

        <!-- Customize your theme here. -->
        <item name="android:textColorPrimary">@color/primary_text</item>
        <item name="android:textColorSecondary">@color/secondary_text</item>
        <item name="android:divider">@color/divider_color</item>

        <!-- Font Application. -->
        <item name="android:fontFamily">@font/iransans</item>
        <item name="fontFamily">@font/iransans</item>

    </style>

    <style name="Theme.EasyNote" parent="Base.Theme.EasyNote" />
</resources>